---
import Layout from '@/layouts/Layout.astro'
import { allWeddingCards } from '@/assets/data/weddings'

const pageTitle = 'Esküvői munkáink | Mimóza Design'
const pageDescription =
  'Esküvői dekorációs portfólió egyedi virágcsokor-megoldásokkal és részletgazdag virágdekorációkkal.'
const pageKeywords =
  'esküvői dekoráció, virágcsokor, esküvői portfólió, menyasszonyi csokor, Mimóza, Mimóza Design, Veszelovszki-Petró Liza, Petró Liza'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Esküvői munkáink',
  description: pageDescription,
  image: '/weddings/dori-david/dori-david-profile.jpg'
}
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} schema={schema}>
  <section class='py-8 sm:py-16 lg:py-24'>
    <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
      <header class='mb-10 space-y-4 text-left sm:mb-14'>
        <h1 class='font-serif text-3xl font-semibold md:text-4xl lg:text-5xl'>Esküvői munkáink</h1>
        <p class='text-muted-foreground max-w-3xl text-lg sm:text-xl'>
          Valódi párok valódi történetei, ahol a virágok, textíliák és részletek egységes hangulattá álltak össze.
          Fedezd fel teljes portfóliónkat.
        </p>
      </header>

      <div class='grid gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-6'>
        {
          allWeddingCards.map((wedding, index) => (
            <article class='border-border bg-card group hover:border-primary overflow-hidden rounded-xl border transition-colors duration-300'>
              <a
                href={`/weddings/${wedding.slug}`}
                aria-label={`${wedding.name} esküvői portfólió megnyitása`}
                class='focus-visible:ring-ring block h-full outline-none focus-visible:ring-2 focus-visible:ring-offset-2'
              >
                <div class='bg-muted'>
                  <img
                    src={wedding.image}
                    alt={wedding.alt}
                    class='aspect-square w-full object-cover transition-transform duration-300 group-hover:scale-105'
                    style={wedding.imagePosition ? `object-position: ${wedding.imagePosition}` : undefined}
                    loading={index < 3 ? 'eager' : 'lazy'}
                  />
                </div>
                <div class='p-4 text-center sm:p-5'>
                  <div class='space-y-1'>
                    <p class='text-primary/90 text-[11px] font-medium tracking-[0.18em] uppercase'>
                      {wedding.location}
                    </p>
                    <h2 class='font-serif text-2xl font-semibold'>{wedding.name}</h2>
                    <p class='text-muted-foreground text-sm tracking-tight'>{wedding.weddingDate}</p>
                  </div>
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
