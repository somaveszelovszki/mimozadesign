---
import Layout from '@/layouts/Layout.astro'
import HeroSection from '@/components/blocks/hero-section/hero-section'
import FeaturedWeddings from '@/components/blocks/featured-weddings-section/featured-weddings'
import AboutUs from '@/components/blocks/about-us-section/about-us-section'
import Testimonials from '@/components/blocks/testimonials-section/testimonials-section'
import Workshops from '@/components/blocks/workshops-section/workshops'
import ContactUsSection from '@/components/blocks/contact-us-section/contact-us-section'

import { featuredWeddings } from '@/assets/data/weddings'
import { testimonials } from '@/assets/data/testimonials'
import { upcomingWorkshops } from '@/assets/data/workshops'
import { contactInfo } from '@/assets/data/contact-us'

// Page-specific SEO configuration
const pageTitle = 'Mimóza Design'
const pageDescription =
  'A Mimóza Design esküvői dekorációt tervez, kreatív workshopokat tart, valamint szárazvirág kompozíciókat, virágcsokrokat és koszorúkat készít.'
const pageKeywords =
  'esküvői dekoráció, kreatív workshop, szárazvirág kompozíció, virágcsokor, koszorú, virágkötészet, menyasszonyi csokor, Mimóza, Mimóza Design, Veszelovszki-Petró Liza, Petró Liza'

// Structured data for better SEO
const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Mimóza Design',
  description: pageDescription,
  image: '/weddings/dori-david/dori-david-profile.jpg',
  url: Astro.site?.toString(),
  areaServed: {
    '@type': 'Country',
    name: 'Magyarország'
  },
  serviceType: ['Esküvői dekoráció', 'Kreatív workshop', 'Szárazvirág kompozíciók', 'Virágcsokrok'],
  offers: {
    '@type': 'Offer',
    priceCurrency: 'HUF'
  },
  author: {
    '@type': 'Organization',
    name: 'Mimóza Design'
  }
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  schema={schema}
  footerClassName='bg-muted'
>
  <HeroSection className='-mt-17.5' client:load />
  <FeaturedWeddings featuredWeddings={featuredWeddings} client:load />
  <div class='w-full py-2' aria-hidden='true'>
    <div class='bg-primary/30 h-[1px] w-full'></div>
  </div>
  <Workshops workshops={[...upcomingWorkshops].sort((a, b) => (a.past ? 1 : 0) - (b.past ? 1 : 0))} />
  <AboutUs />
  <Testimonials testimonials={testimonials} client:load />
  <ContactUsSection contactInfo={contactInfo} />
</Layout>
