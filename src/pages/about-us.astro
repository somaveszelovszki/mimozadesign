---
import Layout from '@/layouts/Layout.astro'

const pageTitle = 'Rólunk | Mimóza Memories'
const pageDescription =
  'Ismerd meg Lizát és a Mimóza Memories történetét: természetes, személyes és időtálló virágdekorációk szeretettel.'
---

<Layout title={pageTitle} description={pageDescription}>
  <section class='about-float-section bg-background py-8 sm:py-16 lg:py-24'>
    <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
      <article class='mx-auto grid max-w-7xl gap-10 lg:grid-cols-2 lg:items-center lg:gap-16'>
        <div class='space-y-4'>
          <p class='text-muted-foreground text-lg'>
            Liza vagyok, virágkötő, textiltervező, építész, feleség és anyuka, a Mimóza Design megálmodója.
          </p>
          <p class='text-muted-foreground text-lg'>
            Már kisgyermekkoromban is nagy boldogsággal töltött el, amikor anyukám virágboltjában ténykedhettem, és
            figyelhettem, ahogyan a virágokból gyönyörű csokrokat varázsol. Már ekkor eldöntöttem, hogy ha nagy leszek,
            én is tervezni, alkotni fogok.
          </p>
        </div>
        <figure
          class='float-on-scroll is-hidden relative mx-auto w-full max-w-[24rem] lg:ml-auto lg:max-w-[28rem]'
        >
          <img
            src='/about-us/about-us-liza-petra-children.jpg'
            alt='Liza gyerekként'
            class='about-section-image'
            loading='lazy'
          />
        </figure>
      </article>
    </div>
  </section>

  <section class='about-float-section bg-white py-8 sm:py-16 lg:py-24'>
    <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
      <article class='mx-auto grid max-w-7xl gap-10 lg:grid-cols-2 lg:items-center lg:gap-16'>
        <figure
          class='float-on-scroll is-hidden relative mx-auto w-full max-w-[24rem] lg:mr-auto lg:max-w-[28rem]'
        >
          <img
            src='/about-us/about-us-liza-amsterdam.jpg'
            alt='Liza Amszterdamban'
            class='about-section-image about-section-image--focus-right'
            loading='lazy'
          />
        </figure>
        <p class='text-muted-foreground text-lg'>
          Ezen ötlettől vezérelve először textiltervező, majd pedig építész lettem. Bár mindkét hivatást nagyon
          szerettem, és lelkesen végeztem, mindig azt éreztem, hogy a természetben, virágok és növények között érzem
          magam igazán jól. Ezért amikor az élet Hollandiába sodort pár évre, ott elszegődtem egy virágboltba Amszterdam
          belvárosában, hogy kitanuljam a szakma csínját-bínját. Lenyűgözött a hollandok mezei stílusú virágkötészete,
          és nagyon hálás vagyok érte, hogy tapasztalatot gyűjthettem benne. Miután férjemmel hazaköltözünk, egyre
          inkább érlelődött bennem egy saját virágdekoros vállalkozás ötlete, és végül így született meg a Mimóza
          Design.
        </p>
      </article>
    </div>
  </section>

  <section class='about-float-section bg-background py-8 sm:py-16 lg:py-24'>
    <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
      <article class='mx-auto grid max-w-7xl gap-10 lg:grid-cols-2 lg:items-center lg:gap-16'>
        <p class='text-muted-foreground text-lg'>
          Az alkotásaimban a Hollandiában tanult természetes, rusztikus, játékossággal átszőtt stílus elevenedik meg.
          Emellett mindig nagy hangsúlyt fektetek arra, hogy a párokkal közösen együttműködve, őket segítve jussunk el
          egy olyan megjelenéshez, amit elképzeltek.
        </p>
        <figure
          class='float-on-scroll is-hidden relative mx-auto w-full max-w-[24rem] lg:ml-auto lg:max-w-[28rem]'
        >
          <img
            src='/about-us/about-us-liza-working.jpg'
            alt='Liza munka közben'
            class='about-section-image'
            loading='lazy'
          />
        </figure>
      </article>
    </div>
  </section>
</Layout>

<script>
  ;(() => {
    const SECTION_SELECTOR = '.about-float-section'
    const PHOTO_SELECTOR = '.float-on-scroll'
    let observer

    const runFloatAnimations = () => {
      const sections = document.querySelectorAll(SECTION_SELECTOR)
      if (!sections.length) return

      if (observer) observer.disconnect()

      for (const section of sections) {
        const photo = section.querySelector(PHOTO_SELECTOR)
        if (!photo) continue
        photo.classList.remove('is-visible')
        photo.classList.add('is-hidden')
      }

      requestAnimationFrame(() => {
        observer = new IntersectionObserver(
          entries => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                const photo = entry.target.querySelector(PHOTO_SELECTOR)
                if (!photo) continue
                photo.classList.add('is-visible')
                photo.classList.remove('is-hidden')
                observer.unobserve(entry.target)
              }
            }
          },
          { threshold: 0.8, rootMargin: '0px' }
        )

        sections.forEach(section => observer.observe(section))
      })
    }

    document.addEventListener(
      'astro:before-swap',
      () => {
        if (observer) observer.disconnect()
      },
      { once: true }
    )

    document.addEventListener('astro:page-load', runFloatAnimations)
    runFloatAnimations()
  })()
</script>

<style>
  .about-section-image {
    aspect-ratio: 16 / 10;
    width: 100%;
    border-radius: 0.75rem;
    border: 1px solid rgb(231 229 228);
    object-fit: cover;
  }

  .about-section-image--focus-right {
    object-position: 92% 50%;
  }

  .float-on-scroll {
    transition: opacity 2000ms ease;
    will-change: opacity;
  }

  .float-on-scroll.is-hidden {
    opacity: 0;
  }

  .float-on-scroll.is-visible {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .float-on-scroll,
    .float-on-scroll.is-hidden {
      opacity: 1;
      transition: none;
    }
  }
</style>
