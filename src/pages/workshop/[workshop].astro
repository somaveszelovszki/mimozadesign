---
import Layout from '@/layouts/Layout.astro'
import type { UpcomingWorkshop } from '@/assets/data/workshops'
import { upcomingWorkshops } from '@/assets/data/workshops'

export function getStaticPaths() {
  return upcomingWorkshops.map(workshop => ({
    params: { workshop: workshop.slug },
    props: { workshop }
  }))
}

interface Props {
  workshop: UpcomingWorkshop
}

const { workshop } = Astro.props as Props

const pageTitle = `${workshop.title} | Workshop | Mimóza Design`
const pageDescription = `${workshop.title} — ${workshop.description}`
const pageImage = workshop.coverImage
---

<Layout title={pageTitle} description={pageDescription} image={pageImage}>
  <section class='bg-background text-foreground mx-auto w-full max-w-7xl px-4 py-10 sm:px-6 sm:py-14 lg:px-8 lg:py-18'>
    <a
      href='/workshop#upcoming-workshops'
      class='text-primary hover:text-primary/80 focus-visible:ring-ring inline-flex items-center gap-2 text-sm font-medium underline-offset-4 hover:underline focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none'
    >
      Vissza a workshopokhoz
    </a>

    <header class='mt-6 flex flex-col gap-8 sm:mt-8 lg:flex-row lg:items-center lg:gap-12'>
      <div class='min-w-0 flex-1 space-y-3'>
        {
          workshop.past && (
            <span class='bg-muted text-muted-foreground inline-block rounded-full px-3 py-1 text-xs font-medium'>
              Korábbi workshop
            </span>
          )
        }
        <h1 class='font-serif text-3xl font-semibold sm:text-4xl lg:text-5xl'>{workshop.title}</h1>
        {
          workshop.details ? (
            <div class='text-muted-foreground space-y-3 text-lg'>
              {workshop.details.map(paragraph => (
                <p>{paragraph}</p>
              ))}
            </div>
          ) : (
            <p class='text-muted-foreground text-lg'>{workshop.description}</p>
          )
        }
      </div>
      <div class='w-full shrink-0 lg:w-80 xl:w-96'>
        <button
          type='button'
          data-gallery-index={workshop.images.indexOf(workshop.coverImage)}
          aria-label='Galéria megnyitása'
          class='focus-visible:ring-ring hover:border-primary group block w-full cursor-pointer overflow-hidden rounded-2xl border border-transparent transition-colors duration-300 outline-none focus-visible:ring-2 focus-visible:ring-offset-2'
        >
          <img
            src={workshop.coverImage}
            alt={workshop.title}
            class='w-full object-cover transition-transform duration-300 group-hover:scale-105'
          />
        </button>
      </div>
    </header>

    <div class='mt-6 space-y-4 sm:mt-8'>
      <h2 class='font-serif text-lg font-medium'>Időpontok</h2>
      <div class='grid gap-3 sm:grid-cols-2'>
        {
          workshop.dates.map(d => (
            <div class='border-border bg-card space-y-1 rounded-xl border p-5'>
              <p class='text-foreground text-sm font-medium'>
                {d.date} | {d.time}
              </p>
              <p class='text-muted-foreground text-sm'>{d.location}</p>
            </div>
          ))
        }
      </div>

      <div class='flex flex-wrap gap-x-6 gap-y-2 text-sm'>
        <p class='text-muted-foreground'>
          <span class='text-foreground font-medium'>Részvételi díj:</span>
          {workshop.price}
          {workshop.priceNote && <span> ({workshop.priceNote})</span>}
        </p>
      </div>

      {
        workshop.discount && (
          <p class='text-muted-foreground text-sm'>
            <span class='text-foreground font-medium'>Kedvezmény:</span>
            {workshop.discount}
          </p>
        )
      }

      {
        workshop.maxParticipants && (
          <p class='text-muted-foreground text-sm'>
            A résztvevők létszáma korlátozott, legfeljebb {workshop.maxParticipants} fő.
          </p>
        )
      }
    </div>

    {
      !workshop.past && workshop.registrationUrl && (
        <div class='mt-6 sm:mt-8'>
          <a
            href={workshop.registrationUrl}
            target='_blank'
            rel='noreferrer'
            class='bg-foreground text-background hover:bg-foreground/90 rounded-full px-8 py-3 text-base font-medium'
          >
            Jelentkezés
          </a>
        </div>
      )
    }
  </section>

  <section class='mx-auto w-full max-w-7xl px-4 pb-10 sm:px-6 sm:pb-14 lg:px-8 lg:pb-18'>
    <div
      id='workshop-gallery'
      class='columns-1 gap-4 sm:columns-2 lg:columns-3'
      data-images={JSON.stringify(workshop.images)}
    >
      {
        workshop.images.map((image, index) =>
          image === workshop.coverImage ? null : (
            <figure class='mb-4 break-inside-avoid overflow-hidden rounded-xl'>
              <button
                type='button'
                data-gallery-index={index}
                aria-label={`${index + 1}. kép megnyitása`}
                class='focus-visible:ring-ring hover:border-primary group block w-full cursor-pointer rounded-lg border border-transparent transition-colors duration-300 outline-none focus-visible:ring-2 focus-visible:ring-offset-2'
              >
                <img
                  src={image}
                  alt={`${workshop.title} galéria kép ${index + 1}`}
                  class='h-auto w-full object-cover transition-transform duration-300 group-hover:scale-105'
                  loading='lazy'
                />
              </button>
            </figure>
          )
        )
      }
    </div>
  </section>

  <div
    id='gallery-lightbox'
    class='bg-background/95 fixed inset-0 z-50 hidden items-center justify-center p-4 backdrop-blur-sm sm:p-8'
    aria-hidden='true'
  >
    <button
      type='button'
      id='gallery-close'
      class='bg-background/70 text-foreground hover:bg-background absolute top-4 right-4 z-10 rounded-full border px-3 py-1.5 text-sm'
      aria-label='Galéria bezárása'
    >
      Bezárás
    </button>

    <button
      type='button'
      id='gallery-prev'
      class='bg-background/70 text-foreground hover:bg-background absolute top-1/2 left-4 z-10 -translate-y-1/2 rounded-full border px-3 py-2 text-2xl leading-none'
      aria-label='Előző kép'
    >
      ‹
    </button>

    <img id='gallery-image' src='' alt='' class='max-h-[90vh] max-w-full rounded-2xl object-contain' />

    <button
      type='button'
      id='gallery-next'
      class='bg-background/70 text-foreground hover:bg-background absolute top-1/2 right-4 z-10 -translate-y-1/2 rounded-full border px-3 py-2 text-2xl leading-none'
      aria-label='Következő kép'
    >
      ›
    </button>
  </div>

  <script is:inline>
    ;(() => {
      const cleanupKey = '__mimozaWorkshopGalleryCleanup'

      const initWorkshopGallery = () => {
        if (typeof window[cleanupKey] === 'function') {
          window[cleanupKey]()
        }

        const gallery = document.querySelector('#workshop-gallery')
        const lightbox = document.querySelector('#gallery-lightbox')
        const lightboxImage = document.querySelector('#gallery-image')
        const closeButton = document.querySelector('#gallery-close')
        const prevButton = document.querySelector('#gallery-prev')
        const nextButton = document.querySelector('#gallery-next')

        if (!gallery || !lightbox || !lightboxImage || !closeButton || !prevButton || !nextButton) {
          window[cleanupKey] = null
          return
        }

        const images = JSON.parse(gallery.getAttribute('data-images') || '[]')
        if (!Array.isArray(images) || images.length === 0) {
          window[cleanupKey] = null
          return
        }

        let activeIndex = 0

        const openLightbox = index => {
          activeIndex = index
          lightboxImage.setAttribute('src', images[activeIndex])
          lightboxImage.setAttribute('alt', `${activeIndex + 1}. workshop galéria kép`)
          lightbox.classList.remove('hidden')
          lightbox.classList.add('flex')
          lightbox.setAttribute('aria-hidden', 'false')
          document.body.style.overflow = 'hidden'
        }

        const closeLightbox = () => {
          lightbox.classList.add('hidden')
          lightbox.classList.remove('flex')
          lightbox.setAttribute('aria-hidden', 'true')
          document.body.style.overflow = ''
        }

        const showRelative = direction => {
          activeIndex = (activeIndex + direction + images.length) % images.length
          lightboxImage.setAttribute('src', images[activeIndex])
          lightboxImage.setAttribute('alt', `${activeIndex + 1}. workshop galéria kép`)
        }

        const onGalleryClick = event => {
          const trigger = event.target.closest('[data-gallery-index]')
          if (!trigger) {
            return
          }
          const index = Number(trigger.getAttribute('data-gallery-index'))
          if (!Number.isFinite(index)) {
            return
          }
          openLightbox(index)
        }

        const onPrevClick = () => showRelative(-1)
        const onNextClick = () => showRelative(1)

        const onLightboxClick = event => {
          if (event.target === lightbox) {
            closeLightbox()
          }
        }

        const onKeyDown = event => {
          if (lightbox.getAttribute('aria-hidden') === 'true') {
            return
          }
          if (event.key === 'Escape') {
            closeLightbox()
          } else if (event.key === 'ArrowLeft') {
            showRelative(-1)
          } else if (event.key === 'ArrowRight') {
            showRelative(1)
          }
        }

        document.addEventListener('click', onGalleryClick)
        closeButton.addEventListener('click', closeLightbox)
        prevButton.addEventListener('click', onPrevClick)
        nextButton.addEventListener('click', onNextClick)
        lightbox.addEventListener('click', onLightboxClick)
        document.addEventListener('keydown', onKeyDown)

        window[cleanupKey] = () => {
          document.removeEventListener('click', onGalleryClick)
          closeButton.removeEventListener('click', closeLightbox)
          prevButton.removeEventListener('click', onPrevClick)
          nextButton.removeEventListener('click', onNextClick)
          lightbox.removeEventListener('click', onLightboxClick)
          document.removeEventListener('keydown', onKeyDown)
          document.body.style.overflow = ''
        }
      }

      initWorkshopGallery()
      document.addEventListener('astro:page-load', initWorkshopGallery)
    })()
  </script>
</Layout>
