---
import WorkshopsCalendar from '@/components/blocks/workshops-section/workshops-calendar'
import { workshops, pastWorkshopHighlight } from '@/assets/data/workshops'
import Layout from '@/layouts/Layout.astro'

const pageTitle = 'Workshopok | Mimóza Design'
const pageDescription =
  'Kreatív workshop események, szárazvirág kompozíciók és virágcsokor-készítési inspirációk a Mimóza Design-tól.'
const pageKeywords =
  'kreatív workshop, DIY workshop, virág workshop, workshop, szárazvirág kompozíció, virágcsokor, koszorú, Mimóza, Mimóza Design, Veszelovszki-Petró Liza, Petró Liza'

const futureWorkshops = workshops.filter(w => !w.past)

const workshopsCalendarEvents = futureWorkshops.flatMap(workshop =>
  workshop.dates.map(d => ({
    title: workshop.title,
    date: d.date,
    time: d.time,
    location: workshop.location,
    slug: workshop.slug,
    isPast: false
  }))
)
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords}>
  <section id='upcoming-workshops' class='bg-muted/40 py-10 sm:py-12 lg:py-14'>
    <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
      <div class='mb-8 space-y-3'>
        <h2 class='font-serif text-2xl font-semibold sm:text-3xl'>Következő workshopok</h2>
        <p class='text-muted-foreground max-w-3xl text-lg'>Válaszd ki a neked tetsző eseményt és jelentkezz!</p>
      </div>

      <div class='grid grid-cols-1 gap-6'>
        {
          futureWorkshops.flatMap(workshop =>
            workshop.dates.map(d => (
              <article class='border-border hover:border-primary bg-card overflow-hidden rounded-xl border transition-colors duration-300 sm:w-1/2'>
                <a href={`/workshop/${workshop.slug}`} class='group flex flex-col sm:flex-row'>
                  <img
                    src={workshop.coverImage}
                    alt={`${workshop.title} borítókép`}
                    class='h-52 w-full object-cover transition-transform duration-300 group-hover:scale-105 sm:h-auto sm:min-h-52 sm:w-72'
                    loading='lazy'
                  />
                  <div class='space-y-3 p-5'>
                    <h3 class='font-serif text-xl font-medium'>{workshop.title}</h3>
                    <p class='text-muted-foreground text-sm'>
                      {d.date} | {d.time}
                    </p>
                    <p class='text-muted-foreground text-sm'>{workshop.location}</p>
                    <p class='text-muted-foreground text-sm'>{workshop.price}</p>
                    <span class='text-primary inline-block text-sm font-medium group-hover:underline'>Részletek</span>
                  </div>
                </a>
              </article>
            ))
          )
        }
      </div>
    </div>
  </section>

  <section id='past-highlights' class='bg-background py-8 sm:py-16 lg:py-24'>
    <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
      <div class='mb-8 max-w-2xl space-y-4 sm:mb-12'>
        <h2 class='font-serif text-2xl font-semibold tracking-tight md:text-3xl lg:text-4xl'>
          {pastWorkshopHighlight.title}
        </h2>
        <p class='text-muted-foreground text-xl leading-relaxed'>
          {pastWorkshopHighlight.description}
        </p>
      </div>

      <div class='columns-2 gap-3 sm:columns-4 sm:gap-4'>
        {
          pastWorkshopHighlight.images.map((image, index) => (
            <div class='mb-3 overflow-hidden rounded-2xl sm:mb-4'>
              <img src={image} alt={`Korábbi workshop kép ${index + 1}`} class='w-full object-cover' loading='lazy' />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section id='workshops-calendar' class='mx-auto w-full max-w-[74rem] px-4 py-10 sm:px-6 sm:py-12 lg:px-8 lg:py-14'>
    <div class='mb-6 space-y-3'>
      <h2 class='font-serif text-2xl font-semibold sm:text-3xl'>Workshop naptár</h2>
      <p class='text-muted-foreground max-w-3xl text-lg'>Interaktív naptár a következő workshop dátumokkal.</p>
    </div>
    <WorkshopsCalendar events={workshopsCalendarEvents} client:visible />
  </section>
</Layout>
